# Azure Document Intelligence
AZURE_DI_ENDPOINT=https://your-di-resource.cognitiveservices.azure.com/
AZURE_DI_KEY=your-document-intelligence-key
# AZURE_DI_MODEL=prebuilt-layout

# Azure OpenAI (Foundry)
AZURE_OPENAI_ENDPOINT=https://oai-th01-swe-d-0001.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-global-poc01
AZURE_OPENAI_API_VERSION=2024-10-21
# Authentication is handled automatically via Entra ID (DefaultAzureCredential)
# Make sure you are logged in using `az login` or have correct environment variables set.
# AZURE_OPENAI_API_VERSION=2024-05-01-preview

# Optional: Override defaults (see config/settings.py for all options)
# LLM_TEMPERATURE=0.0
# LLM_TIMEOUT=30
# MAX_PAGES=2
# MAX_CONCURRENCY=5
# LOG_FORMAT=console

# LangGraph HITL Settings
# MARGIN_THRESHOLD=1.5
# CHECKPOINT_DB_PATH=./checkpoints/doc_cls.db
# LOGPROBS_TOP_N=3

# LangSmith Tracing
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=docguru-cls
